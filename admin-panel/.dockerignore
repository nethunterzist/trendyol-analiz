.env
.env.*
.env.local
.env.development
.env.production

# Documentation
README.md
CLAUDE.md
*.md
docs/

# Git files
.git/
.gitignore
.gitattributes

# Docker files (not needed in container)
Dockerfile
docker-compose.yml
.dockerignore

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# Cache directories
.cache/
.eslintcache

